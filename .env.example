# Copy to `.env` and adjust. Same variable names work for:
# - `npm run dev` (loaded via Vite from the project root)
# - `docker compose -f docker-compose.sync.yml` (substituted into the chartdb service environment)

# Diagram sync (see sync-server/README.md)
DIAGRAM_SYNC_API_ENABLED=false
DIAGRAM_SYNC_POLL_MS=30000
DIAGRAM_SYNC_API_BASE=/api/diagram-sync
# Optional Bearer token; must match sync-server SYNC_API_TOKEN if set
DIAGRAM_SYNC_TOKEN=
